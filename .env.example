# ===========================================
# Audit-X Pipeline - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# -------------------------------------------
# PostgreSQL Database
# -------------------------------------------
POSTGRES_USER=audit_x
POSTGRES_PASSWORD=your_secure_password_here

# -------------------------------------------
# Rails Application
# -------------------------------------------
# Generate with: docker compose exec web bin/rails secret
# Only required in production
RAILS_MASTER_KEY=

# -------------------------------------------
# InfluxDB (Time-series database)
# -------------------------------------------
INFLUXDB_INIT_PASSWORD=your_influx_password_here
INFLUX_TOKEN=your_influx_token_here
INFLUX_ORG=audit-x
INFLUX_BUCKET=gastos

# -------------------------------------------
# Grafana (Visualization)
# -------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=your_grafana_password_here

# -------------------------------------------
# MinIO / S3 Compatible Storage
# -------------------------------------------
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=your_minio_password_here

# -------------------------------------------
# Google Sheets API (only for AMEX extractor)
# -------------------------------------------
# Base64 encoded service account JSON
# Generate: cat credentials.json | base64 -w 0
GOOGLE_JSON_CONTENT=

# -------------------------------------------
# GitHub Container Registry (production only)
# -------------------------------------------
# GHCR_WEB_IMAGE=ghcr.io/your-user/personal-obs-pipeline-web:latest
# GHCR_INGESTION_IMAGE=ghcr.io/your-user/personal-obs-pipeline-ingestion:latest
