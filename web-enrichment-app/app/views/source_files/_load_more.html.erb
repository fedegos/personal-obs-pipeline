<div id="source-files-next-page">
  <% if next_page.present? %>
    <div class="source-files-pagination-container"
         data-controller="infinite-scroll"
         data-infinite-scroll-next-url-value="<%= upload_path(page: next_page, format: :turbo_stream) %>">
      <div class="transactions-pagination-sentinel" data-infinite-scroll-target="sentinel" aria-hidden="true"></div>
      <button type="button"
              class="btn-secondary-action"
              data-infinite-scroll-target="button"
              data-action="click->infinite-scroll#loadMore">
        Cargar más
      </button>
      <span class="transactions-pagination-status" data-infinite-scroll-target="status"></span>
    </div>
  <% end %>
</div>
