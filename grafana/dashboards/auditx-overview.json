            "query": "from(bucket: \"finanzas\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"kafka_consumer\")\r\n  |> filter(fn: (r) => r[\"_field\"] == \"monto\")\r\n  // 1. Forzamos que TODO sea una sola tabla eliminando todos los tags\r\n  |> group() \r\n  // 2. Agrupamos por tiempo (esto crea la base del gráfico)\r\n  |> aggregateWindow(every: 1d, fn: sum, createEmpty: true)\r\n  // 3. Llenamos con ceros los huecos donde no hubo gasto antes de acumular\r\n  |> fill(value: 0.0)\r\n  // 4. Acumulamos\r\n  |> cumulativeSum() \r\n  |> yield(name: \"total_real\")",
