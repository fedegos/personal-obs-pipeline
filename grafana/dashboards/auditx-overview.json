            "query": "from(bucket: \"finanzas\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"kafka_consumer\")\r\n  // 1. Traemos monto y categoria (ahora ambos son Fields)\r\n  |> filter(fn: (r) => r[\"_field\"] == \"monto\" or r[\"_field\"] == \"categoria\")\r\n  // 2. Pivotamos para tener categoria y monto en la misma fila\r\n  |> pivot(rowKey:[\"_time\", \"event_id\"], columnKey: [\"_field\"], valueColumn: \"_value\")\r\n  // 3. Agrupamos por la columna categoria (que nació del pivot)\r\n  |> group(columns: [\"categoria\"])\r\n  // 4. aggregateWindow ahora debe saber que el valor está en la columna \"monto\"\r\n  |> aggregateWindow(every: 1w, fn: sum, column: \"monto\", createEmpty: false)\r\n  |> group(columns: [\"categoria\"])\r\n  |> drop(columns: [\"_start\", \"_stop\", \"_field\"]) // Quitamos el rastro del nombre del campo\r\n  |> rename(columns: {monto: \"_value\"}) // Renombramos a _value para que Grafana use el estándar\r\n  // 5. Limpieza final para Grafana\r\n  |> yield(name: \"Gastos Semanales\")",
            "refId": "A"
