          {
            "query": "import \"date\"\r\n\r\nmes_inicio = date.truncate(t: now(), unit: 1mo)\r\n\r\nfrom(bucket: \"finanzas\")\r\n  |> range(start: mes_inicio) \r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"kafka_consumer\")\r\n  |> filter(fn: (r) => r[\"_field\"] == \"monto\")\r\n  |> group() // <--- UNIFICA TODAS LAS CATEGORÍAS AQUÍ\r\n  |> aggregateWindow(every: 1d, fn: sum, createEmpty: true)\r\n  |> fill(column: \"_value\", value: 0.0)\r\n  |> cumulativeSum()\r\n  // CAMBIO CLAVE: Renombramos la columna de valor para Grafana\r\n  |> map(fn: (r) => ({ r with _field: \"monto\", Mes: \"Mes Actual\" })) // Agregamos el tag 'Mes'\r\n  |> group(columns: [\"Mes\"]) // <--- ESTO ES VITAL\r\n\r\n",
            "refId": "A"
