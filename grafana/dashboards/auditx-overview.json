        "targets": [
          {
            "query": "import \"date\"\r\n\r\nfrom(bucket: \"finanzas\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"kafka_consumer\")\r\n  |> filter(fn: (r) => r[\"_field\"] == \"monto\")\r\n  // 1. Creamos la etiqueta del día ANTES de agrupar\r\n  |> map(fn: (r) => ({\r\n      r with \r\n      dia: if date.weekDay(t: r._time) == 0 then \"0. Dom\"\r\n           else if date.weekDay(t: r._time) == 1 then \"1. Lun\"\r\n           else if date.weekDay(t: r._time) == 2 then \"2. Mar\"\r\n           else if date.weekDay(t: r._time) == 3 then \"3. Mié\"\r\n           else if date.weekDay(t: r._time) == 4 then \"4. Jue\"\r\n           else if date.weekDay(t: r._time) == 5 then \"5. Vie\"\r\n           else \"6. Sáb\"\r\n    }))\r\n  // 2. Agrupamos por esa columna 'dia'\r\n  |> group(columns: [\"dia\"])\r\n  // 3. Sumamos los valores de cada grupo\r\n  |> sum(column: \"_value\")\r\n  // 4. IMPORTANTE: Esto convierte las tablas separadas en una sola tabla legible\r\n  |> group()",
            "refId": "A"
          }
        ],
        "title": "Perfil por día de la semana",
        "transformations": [
          {
            "id": "merge",
            "options": {}
          }
        ],
        "type": "barchart"
