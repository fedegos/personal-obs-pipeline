          {
            "datasource": {
              "type": "influxdb",
              "uid": "afan8s6uxjpc0e"
            },
            "hide": false,
            "query": "import \"date\"\r\nimport \"experimental\"\r\n\r\nmes_pasado_inicio = date.truncate(t: experimental.addDuration(d: -1mo, to: now()), unit: 1mo)\r\nmes_pasado_fin = date.truncate(t: now(), unit: 1mo)\r\n\r\nfrom(bucket: \"finanzas\")\r\n  |> range(start: mes_pasado_inicio, stop: mes_pasado_fin)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"kafka_consumer\")\r\n  |> filter(fn: (r) => r[\"_field\"] == \"monto\")\r\n  |> group() // <--- UNIFICA TODAS LAS CATEGORÍAS AQUÍ\r\n  |> aggregateWindow(every: 1d, fn: sum, createEmpty: true)\r\n  |> fill(column: \"_value\", value: 0.0)\r\n  |> cumulativeSum()\r\n  |> timeShift(duration: 1mo)\r\n  |> map(fn: (r) => ({ r with _field: \"monto\", Mes: \"Mes Anterior\" })) // Agregamos el tag 'Mes'\r\n  |> group(columns: [\"Mes\"]) // <--- ESTO ES VITAL\r\n\r\n",
            "refId": "B"
          }
        ],
        "title": "Mes actual contra anterior",
        "type": "timeseries"
