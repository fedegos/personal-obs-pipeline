        "id": 9,
        "options": {
          "cellHeight": "sm",
          "frameIndex": 3,
          "showHeader": true
        },
        "pluginVersion": "12.3.1",
        "targets": [
          {
            "query": "import \"date\"\r\n\r\n// 1. Definimos periodos de 30 días para que tus datos entren en \"Actual\"\r\nahora = now()\r\nhaceTreintaDias = date.add(d: -30d, to: ahora)\r\nhaceSesentaDias = date.add(d: -60d, to: ahora)\r\n\r\ndata = from(bucket: \"finanzas\")\r\n  |> range(start: haceSesentaDias) \r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"kafka_consumer\")\r\n  |> filter(fn: (r) => r[\"_field\"] == \"monto\" or r[\"_field\"] == \"categoria\")\r\n  |> map(fn: (r) => ({ r with _time: date.truncate(t: r._time, unit: 1s) }))\r\n  |> pivot(rowKey:[\"_time\", \"event_id\"], columnKey: [\"_field\"], valueColumn: \"_value\")\r\n  |> filter(fn: (r) => exists r.categoria and exists r.monto)\r\n\r\nstats = data\r\n  |> map(fn: (r) => ({\r\n      r with\r\n      // Ahora el punto de corte son 30 días\r\n      periodo: if r._time >= haceTreintaDias then \"actual\" else \"pasado\"\r\n    }))\r\n  |> group(columns: [\"categoria\", \"periodo\"])\r\n  |> sum(column: \"monto\")\r\n  |> group(columns: [\"categoria\"])\r\n  |> pivot(rowKey:[\"categoria\"], columnKey: [\"periodo\"], valueColumn: \"monto\")\r\n\r\nstats\r\n  |> map(fn: (r) => ({\r\n      categoria: r.categoria,\r\n      actual: if exists r.actual then r.actual else 0.0,\r\n      pasado: if exists r.pasado then r.pasado else 0.0,\r\n      diferencia: (if exists r.actual then r.actual else 0.0) - (if exists r.pasado then r.pasado else 0.0),\r\n      variacion_pct: \r\n        if exists r.pasado and r.pasado > 0.0 then \r\n            ((if exists r.actual then r.actual else 0.0) - r.pasado) / r.pasado * 100.0 \r\n        else if (if exists r.actual then r.actual else 0.0) > 0.0 then \r\n            99999.0 // Aquí es donde tratamos el \"Infinito\" (pasado 0, actual > 0)\r\n        else \r\n            0.0\r\n    }))\r\n  |> group() \r\n  |> sort(columns: [\"actual\"], desc: true)\r\n  |> keep(columns: [\"categoria\", \"actual\", \"pasado\", \"diferencia\", \"variacion_pct\"])",
            "refId": "A"
          }
        ],
        "title": "Comparativa month-on-month",
        "type": "table"
      },
